# Groq LLM (free tier — 30 req/min)
GROQ_API_KEY=your_groq_api_key_here

# YouTube OAuth (required for YT uploads)
YT_CLIENT_ID=your_client_id
YT_CLIENT_SECRET_VALUE=your_client_secret
YT_REFRESH_TOKEN=your_refresh_token

# Instagram (required for Reels uploads)
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Pipeline settings (optional overrides)
BRAINROT_STYLE="chaotic"          # chaotic / meme / story / npc
CLIP_LENGTH_MIN=15                # minimum clip length in seconds
CLIP_LENGTH_MAX=40                # maximum clip length in seconds
EDGE_TTS_VOICE=en-US-EricNeural   # TTS voice for voiceover
YOUTUBE_PRIVACY=public            # public / unlisted / private